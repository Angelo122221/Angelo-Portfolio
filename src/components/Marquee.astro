---
import { techStack } from '../data/skills';

// We double the array to create a seamless infinite loop
const displayLogos = [...techStack, ...techStack];
---

<section class="py-12 border-y border-black/5 overflow-hidden relative group">
    <div class="marquee-content group-hover:[animation-play-state:paused]">
        {displayLogos.map((tech) => (
            <div class="mx-12 flex items-center justify-center">
                <img 
                    src={`https://cdn.simpleicons.org/${tech.icon}/666666`} 
                    alt={tech.name} 
                    title={tech.name}
                    class="h-8 grayscale opacity-40 hover:opacity-100 hover:grayscale-0 transition-all duration-300 cursor-help"
                />
            </div>
        ))}
    </div>
    
    {/* Fade effect on the edges */}
    <div class="absolute inset-y-0 left-0 w-24 bg-gradient-to-r from-[#fafafa] to-transparent pointer-events-none"></div>
    <div class="absolute inset-y-0 right-0 w-24 bg-gradient-to-l from-[#fafafa] to-transparent pointer-events-none"></div>
</section>