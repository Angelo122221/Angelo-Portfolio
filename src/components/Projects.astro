---
const projects = [
    { 
        title: "SubanenGo", 
        category: "Full Stack / TypeScript, Tailwind CSS, Node.js", 
        description: "Language learning platform for the Subanen dialect with interactive lessons.",
        image: "/assets/projects/SubanenGO.png", 
        year: "2025",
        link: "https://subanengo-app.vercel.app/"
    },
    { 
        title: "TUFACOP Bookkeeping System", 
        category: "Full Stack / Vue, Laravel", 
        description: "Financial management and report generation system for cooperatives.",
        image: "/assets/projects/tufacop.png", 
        year: "2024" 
    },
    { 
        title: "SymptoQuest", 
        category: "UI Design & System Architecture", 
        description: "Diagnostic assistance tool focusing on intuitive UI and medical data flow.",
        image: "/assets/projects/symptoquest.png", 
        year: "2023" 
    }
];
---

<div class="py-4">
    <section class="space-y-6">
        <div class="flex items-center gap-4">
            <h3 class="text-lg font-bold uppercase tracking-tighter leading-none">Recent Projects</h3>
            <div class="h-[2px] flex-grow bg-gray-100 rounded-full"></div>
        </div>

        <div class="relative bg-white border border-gray-100 rounded-[32px] p-8 shadow-[0_20px_60px_-15px_rgba(0,0,0,0.12)]">
            
            <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                {projects.slice(0, 3).map(p => (
                    <div class="group relative">
                        <div class="aspect-video bg-gray-50 rounded-2xl overflow-hidden mb-4 relative border border-gray-100">
                            <img 
                                src={p.image} 
                                alt={p.title}
                                class="w-full h-full object-cover transform group-hover:scale-110 transition-transform duration-1000 ease-out" 
                                loading="lazy"
                            />
                            
                            <div class="absolute inset-0 bg-black/90 opacity-0 group-hover:opacity-100 transition-opacity duration-500 flex flex-col justify-center p-6 z-20">
                                <p class="text-[#bef264] text-[9px] font-mono mb-2 uppercase tracking-[0.3em] font-bold">Details</p>
                                <p class="text-white/80 text-[12px] leading-relaxed">
                                    {p.description}
                                </p>
                            </div>

                            <span class="absolute top-3 right-3 bg-black/80 backdrop-blur-md text-[9px] text-white px-2 py-0.5 rounded-full font-mono z-10 border border-white/10">
                                {p.year}
                            </span>
                        </div>
                        
                        <div class="px-1">
                            <h4 class="font-black text-[14px] uppercase tracking-tight text-gray-900">
                                {p.link ? (
                                    <a href={p.link} target="_blank" rel="noopener noreferrer" class="hover:text-[#65a30d] transition-colors inline-flex items-center gap-1.5">
                                        {p.title} <span class="text-[10px] opacity-30">↗</span>
                                    </a>
                                ) : (
                                    p.title
                                )}
                            </h4>
                            <p class="text-[10px] text-gray-400 font-bold uppercase tracking-wider mt-1">
                                {p.category}
                            </p>
                        </div>
                    </div>
                ))}

                <button 
                    id="open-projects-modal"
                    class="aspect-video bg-[#111111] rounded-2xl flex flex-col items-center justify-center group hover:bg-black transition-all duration-500 shadow-lg border border-white/5 active:scale-95"
                >
                    <div class="w-12 h-12 rounded-full border border-white/10 flex items-center justify-center mb-3 group-hover:border-[#bef264]/40 transition-all duration-500">
                        <span class="text-[#bef264] text-xl group-hover:translate-x-1 transition-transform">→</span>
                    </div>
                    <span class="text-white font-bold text-[9px] uppercase tracking-[0.3em]">View Archive</span>
                </button>
            </div>
        </div>
    </section>
</div>

<div id="projects-modal" class="fixed inset-0 z-[100] hidden items-center justify-center p-6">
    <div class="absolute inset-0 bg-black/80 backdrop-blur-xl transition-opacity duration-500 opacity-0" id="modal-overlay"></div>
    
    <div 
        id="modal-content"
        class="relative w-full max-w-4xl bg-white rounded-[40px] shadow-2xl overflow-hidden transform scale-95 opacity-0 transition-all duration-500"
    >
        <button id="close-modal" class="absolute top-8 right-8 w-10 h-10 flex items-center justify-center rounded-full bg-gray-50 text-gray-400 hover:bg-black hover:text-white transition-all z-30 font-bold text-xs">
            ✕
        </button>

        <div class="p-10 md:p-14 max-h-[85vh] overflow-y-auto custom-scrollbar">
            <header class="mb-12">
                <p class="text-[#65a30d] font-mono text-[10px] font-black uppercase tracking-widest mb-2">History</p>
                <h2 class="text-4xl font-black uppercase tracking-tighter text-gray-950">Full Archive</h2>
                <div class="w-12 h-1 bg-[#bef264] mt-4 rounded-full"></div>
            </header>

            <div class="grid grid-cols-1 gap-4">
                {projects.map(p => (
                    <div class="group flex flex-col md:flex-row gap-6 p-4 rounded-3xl hover:bg-gray-50 transition-all border border-transparent hover:border-gray-100">
                        <div class="w-full md:w-40 aspect-video rounded-xl overflow-hidden bg-gray-100 flex-shrink-0">
                            <img src={p.image} alt={p.title} class="w-full h-full object-cover" />
                        </div>
                        <div class="flex flex-col justify-center">
                            <div class="flex items-center gap-3 mb-1">
                                <span class="text-[9px] font-mono font-bold bg-black text-[#bef264] px-2 py-0.5 rounded uppercase">{p.year}</span>
                                <h3 class="font-black text-xl uppercase tracking-tight text-gray-900">{p.title}</h3>
                            </div>
                            <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-2">{p.category}</p>
                            <p class="text-sm text-gray-500 leading-relaxed line-clamp-2">{p.description}</p>
                        </div>
                    </div>
                ))}
            </div>
        </div>
    </div>
</div>

<style>
    .custom-scrollbar::-webkit-scrollbar { width: 4px; }
    .custom-scrollbar::-webkit-scrollbar-track { background: transparent; }
    .custom-scrollbar::-webkit-scrollbar-thumb { background: #e5e7eb; border-radius: 10px; }
</style>

<script>
    function setupProjectsModal() {
        const modal = document.getElementById('projects-modal');
        const modalContent = document.getElementById('modal-content');
        const overlay = document.getElementById('modal-overlay');
        const openBtn = document.getElementById('open-projects-modal');
        const closeBtn = document.getElementById('close-modal');

        const openModal = () => {
            modal?.classList.remove('hidden');
            modal?.classList.add('flex');
            document.body.style.overflow = 'hidden';
            setTimeout(() => {
                overlay?.classList.remove('opacity-0');
                modalContent?.classList.remove('scale-95', 'opacity-0');
            }, 10);
        };

        const closeModal = () => {
            overlay?.classList.add('opacity-0');
            modalContent?.classList.add('scale-95', 'opacity-0');
            setTimeout(() => {
                modal?.classList.add('hidden');
                modal?.classList.remove('flex');
                document.body.style.overflow = 'auto';
            }, 500);
        };

        openBtn?.addEventListener('click', openModal);
        closeBtn?.addEventListener('click', closeModal);
        overlay?.addEventListener('click', closeModal);
        document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeModal(); });
    }

    setupProjectsModal();
    document.addEventListener('astro:after-swap', setupProjectsModal);
</script>