---
const projects = [
    { 
        title: "SubanenGo", 
        category: "Full Stack / TypeScript, Tailwind CSS, Node.js", 
        description: "Language learning platform for the Subanen dialect with interactive lessons.",
        image: "/assets/projects/SubanenGO.png", 
        year: "2025",
        link: "https://subanengo-app.vercel.app/"
    },
    { 
        title: "TUFACOP Bookkeeping System", 
        category: "Full Stack / Vue, Laravel", 
        description: "Financial management and report generation system for cooperatives.",
        image: "/assets/projects/tufacop.png", 
        year: "2024" 
    },
    { 
        title: "SymptoQuest", 
        category: "UI Design & System Architecture", 
        description: "Diagnostic assistance tool focusing on intuitive UI and medical data flow.",
        image: "/assets/projects/symptoquest.png", 
        year: "2023" 
    }
];
---

<section class="space-y-8">
    <div class="flex items-center justify-between">
        <h3 class="text-lg font-bold uppercase tracking-tighter">Recent Projects</h3>
        <div class="h-[1px] flex-grow mx-4 bg-gray-100 hidden md:block"></div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-10">
        {projects.map(p => (
            <div class="group relative">
                <div class="aspect-video bg-white rounded-2xl overflow-hidden mb-5 relative shadow-[0_8px_30px_rgb(0,0,0,0.04)] group-hover:shadow-[0_20px_50px_rgba(0,0,0,0.1)] transition-all duration-500 border border-gray-100/50">
                    
                    <img 
                        src={p.image} 
                        alt={p.title}
                        class="w-full h-full object-cover transform group-hover:scale-105 transition-transform duration-700" 
                        loading="lazy"
                    />
                    
                    <div class="absolute inset-0 bg-black/90 opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex flex-col justify-center p-8 z-20">
                        <p class="text-[#bef264] text-[10px] font-mono mb-3 uppercase tracking-[0.3em] font-bold">Project Overview</p>
                        <p class="text-white/90 text-[13px] leading-relaxed font-medium">
                            {p.description}
                        </p>
                        {p.link && (
                             <div class="mt-6">
                                <span class="text-white text-[10px] uppercase font-bold tracking-widest border-b border-[#bef264] pb-1">Visit Live Site →</span>
                             </div>
                        )}
                    </div>

                    <span class="absolute top-4 right-4 bg-black/80 backdrop-blur-md text-[10px] text-white px-3 py-1 rounded-full font-mono z-10 border border-white/10">
                        {p.year}
                    </span>
                </div>
                
                <div class="px-1 space-y-1.5">
                    <h4 class="font-black text-[15px] uppercase tracking-tight text-gray-900">
                        {p.link ? (
                            <a href={p.link} target="_blank" rel="noopener noreferrer" class="hover:text-[#65a30d] transition-colors flex items-center gap-2">
                                {p.title} <span class="text-[10px] opacity-30">↗</span>
                            </a>
                        ) : (
                            p.title
                        )}
                    </h4>
                    <p class="text-[11px] text-gray-400 font-bold uppercase tracking-wider">
                        {p.category}
                    </p>
                </div>
            </div>
        ))}

        <button 
            id="open-projects-modal"
            class="aspect-video bg-[#1a1a1a] rounded-2xl flex flex-col items-center justify-center group hover:bg-black transition-all duration-300 shadow-xl border border-white/5"
        >
            <div class="w-12 h-12 rounded-full border border-white/10 flex items-center justify-center mb-4 group-hover:scale-110 transition-transform">
                <span class="text-[#bef264] text-2xl group-hover:translate-x-1 transition-transform">→</span>
            </div>
            <span class="text-white font-bold text-[10px] uppercase tracking-[0.25em]">Explore Archive</span>
        </button>
    </div>
</section>

<div id="projects-modal" class="fixed inset-0 z-[100] hidden">
    <div class="absolute inset-0 bg-black/60 backdrop-blur-md" id="modal-overlay"></div>
    <div class="absolute right-0 top-0 h-full w-full max-w-xl bg-white p-12 shadow-2xl overflow-y-auto transform transition-transform duration-500 ease-out translate-x-full" id="modal-content">
        <button id="close-modal" class="absolute top-10 right-10 text-[11px] font-black uppercase tracking-widest text-gray-400 hover:text-black transition-colors">
            CLOSE [✕]
        </button>
        
        <div class="space-y-2 mb-16">
            <h2 class="text-3xl font-black uppercase tracking-tighter">Project Archive</h2>
            <p class="text-[11px] font-mono text-gray-400 uppercase tracking-widest">A collection of past works and experiments</p>
        </div>

        <div class="space-y-12">
            <div class="group border-l-2 border-gray-100 pl-6 py-2 hover:border-[#bef264] transition-colors">
                <p class="text-[10px] font-mono text-[#65a30d] mb-1">2023 - UI DESIGN</p>
                <h3 class="font-bold text-lg uppercase tracking-tight">SymptoQuest Architecture</h3>
                <p class="text-sm text-gray-500 leading-relaxed mt-2">In-depth medical system flow and intuitive diagnostic UI components.</p>
            </div>
            
            <div class="p-8 rounded-2xl bg-gray-50 border border-dashed border-gray-200 text-center">
                <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest">More entries being documented...</p>
            </div>
        </div>
    </div>
</div>

<script>
    const modal = document.getElementById('projects-modal');
    const modalContent = document.getElementById('modal-content');
    const openBtn = document.getElementById('open-projects-modal');
    const closeBtn = document.getElementById('close-modal');
    const overlay = document.getElementById('modal-overlay');

    const openModal = () => {
        modal?.classList.remove('hidden');
        setTimeout(() => {
            modalContent?.classList.remove('translate-x-full');
        }, 10);
        document.body.style.overflow = 'hidden';
    };

    const closeModal = () => {
        modalContent?.classList.add('translate-x-full');
        setTimeout(() => {
            modal?.classList.add('hidden');
        }, 500);
        document.body.style.overflow = 'auto';
    };

    openBtn?.addEventListener('click', openModal);
    closeBtn?.addEventListener('click', closeModal);
    overlay?.addEventListener('click', closeModal);
</script>